import { useEffect, useRef, useState } from 'react';
import { useMessageStore } from './useMessageStore';

// Сообщения бота для тестирования
const botMessages = [
  "Привет! Я бот Axora 🤖",
  "Как дела?",
  "Ты ещё тут?",
  "Нравится чат?",
  "Скоро выйдет новая фича 😉",
  "Отличная погода сегодня!",
  "Что нового?",
  "Как прошёл день?",
  "У тебя есть планы на выходные?",
  "Можешь рассказать что-нибудь интересное?",
  "Я всегда готов помочь!",
  "Технологии развиваются так быстро...",
  "Любишь программирование?",
  "Какой твой любимый язык программирования?",
  "У тебя есть мечта?",
  "Что тебя вдохновляет?",
  "Расскажи о своих увлечениях",
  "Какой фильм посмотрел недавно?",
  "Любишь путешествовать?",
  "Что думаешь об ИИ?",
];

export const useBotProvider = () => {
  const [isBotEnabled, setIsBotEnabled] = useState(false);
  const addBotMessage = useMessageStore((s) => s.addBotMessage);
  const intervalRef = useRef<ReturnType<typeof setTimeout> | null>(null);

  // Функция для отправки случайного сообщения от бота
  const sendBotMessage = () => {
    try {
      const randomMessage = botMessages[Math.floor(Math.random() * botMessages.length)];
      addBotMessage(randomMessage);
      console.log('🤖 Bot message sent:', randomMessage);
    } catch (error) {
      console.error('❌ Error sending bot message:', error);
    }
  };

  // Устанавливаем интервал (5-10 секунд случайно)
  const startInterval = () => {
    const delay = Math.random() * 5000 + 5000; // 5-10 секунд
    
    intervalRef.current = setTimeout(() => {
      if (isBotEnabled) {
        sendBotMessage();
        startInterval(); // Рекурсивно устанавливаем следующий интервал
      }
    }, delay);
  };

  // Очистка интервала
  const stopInterval = () => {
    if (intervalRef.current) {
      clearTimeout(intervalRef.current);
      intervalRef.current = null;
    }
  };

  // Переключатель бота
  const toggleBot = () => {
    const newState = !isBotEnabled;
    setIsBotEnabled(newState);
    
    if (newState) {
      console.log('🤖 Bot enabled');
      startInterval();
    } else {
      console.log('🤖 Bot disabled');
      stopInterval();
    }
  };

  // Эффект для управления ботом
  useEffect(() => {
    if (isBotEnabled) {
      startInterval();
    } else {
      stopInterval();
    }

    return () => {
      stopInterval();
    };
  }, [isBotEnabled]);

  return {
    isBotEnabled,
    toggleBot,
  };
}; 
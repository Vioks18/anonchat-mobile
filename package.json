{
  "name": "anonchat-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "_comment": "⚠️ ЗАЩИЩЕНО: app/components/ChatCore.tsx - НЕ ТРОГАТЬ! См. CHATCORE-PROTECTION.md",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "backup": "node ./scripts/backup.js backup",
    "backup:create": "node ./scripts/backup.js backup",
    "backup:list": "node ./scripts/backup.js list",
    "backup:restore": "node ./scripts/backup.js restore",
    "analyze": "node ./scripts/project-analyzer.js",
    "monitor": "node ./scripts/live-monitor.js",
    "assistant": "node ./scripts/smart-assistant-modular.js",
    "generate": "node ./scripts/component-generator.js",
    "update-report": "node ./scripts/auto-update-report.js",
    "guard": "node ./scripts/regression-guard.js",
    "safe-create": "node ./scripts/safe-component-generator.js",
    "protect": "node ./scripts/protect-chatcore.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "qa": "node scripts/qa/scan.js",
    "qa:soft": "cross-env QA_MODE=soft node scripts/qa/scan.js",
    "qa:strict": "cross-env QA_MODE=strict node scripts/qa/scan.js",
    "qa:corridor": "node scripts/qa/corridor.js",
    "qa:debug": "node scripts/qa/scan.js --debug",
    "qa:fix": "node scripts/qa/scan.js --autofix",
    "qa:ui": "node scripts/qa/scan.js --mode=ui",
    "qa:perf": "node scripts/qa/scan.js --mode=perf",
    "qa:baseline:update": "node scripts/qa/scan.js && cp QA-REPORT.md qa-baseline.json",
    "qa:oneclick": "powershell -ExecutionPolicy Bypass -File scripts/qa/quick-fix.ps1",
    "qa:gestures": "node scripts/sim/run.js --tapdiag && node scripts/qa/scan.js",
    "qa:strict:gestures": "node scripts/sim/run.js --tapdiag && node -e \"process.env.QA_MODE='strict';require('./scripts/qa/scan.js')\"",
    "sim": "node scripts/sim/run.js",
    "qa:sim": "npm run qa && npm run sim",
    "stats:loc": "node scripts/stats/loc.js",
    "guard:install": "node scripts/guard/install-precommit.js",
    "guard:snapshot": "git add -A && git commit -m \"chore: snapshot before feature\" && git tag -f STABLE",
    "guard:test": "node scripts/sim/run.js --stress",
    "prefeature": "node scripts/prefeature.js",
    "fix:android": "node scripts/fix-android-build.js",
    "android:fix": "node scripts/quick-android-fix.js",
    "android:fix:ps": "powershell -ExecutionPolicy Bypass -File scripts/fix-android-windows.ps1",
    "android:dev": "eas build -p android --profile dev-client",
    "android:apk": "eas build -p android --profile preview",
    "pre-eject-check": "node scripts/eject/guard.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/stack": "^7.4.7",
    "@types/lodash": "^4.17.20",
    "expo": "~53.0.20",
    "expo-background-fetch": "^13.1.6",
    "expo-blur": "~14.1.5",
    "expo-camera": "~16.1.11",
    "expo-clipboard": "~7.1.5",
    "expo-constants": "~17.1.7",
    "expo-contacts": "~14.2.5",
    "expo-crypto": "^14.1.5",
    "expo-dev-client": "~5.2.4",
    "expo-device": "~7.1.4",
    "expo-document-picker": "~13.1.6",
    "expo-file-system": "~18.1.11",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.4.0",
    "expo-image-picker": "~16.1.4",
    "expo-linear-gradient": "~14.1.5",
    "expo-linking": "~7.1.7",
    "expo-location": "~18.1.6",
    "expo-media-library": "~17.1.7",
    "expo-network": "~7.1.5",
    "expo-notifications": "^0.31.4",
    "expo-router": "~5.1.4",
    "expo-secure-store": "~14.2.3",
    "expo-sharing": "~13.1.5",
    "expo-splash-screen": "~0.30.10",
    "expo-sqlite": "^15.2.14",
    "expo-status-bar": "~2.2.3",
    "expo-symbols": "~0.4.5",
    "expo-system-ui": "~5.0.10",
    "expo-task-manager": "^13.1.6",
    "expo-updates": "^0.28.17",
    "expo-web-browser": "~14.2.0",
    "firebase": "^12.1.0",
    "lodash": "^4.17.21",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.5",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-haptic-feedback": "^2.3.3",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-portalize": "^1.0.7",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-swipe-list-view": "^3.2.9",
    "react-native-web": "~0.20.0",
    "react-native-webview": "13.13.5",
    "zustand": "^5.0.7",
    "expo-build-properties": "~0.14.8"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.0.10",
    "chokidar": "^4.0.3",
    "cross-env": "^10.0.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~9.2.0",
    "nodemon": "^3.1.10",
    "typescript": "~5.8.3"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-keyboard-aware-scroll-view",
          "react-native-swipe-list-view",
          "firebase",
          "react-native-portalize"
        ]
      }
    }
  }
}

{
  "firestore": {


    "rules": "firebase/firestore.rules"
  },
  "hosting": {
    "public": "web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/auth/**",
        "destination": "/auth/index.html"
      }
    ]
  }
}
